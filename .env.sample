# .env.sample - Environment configuration template
# Copy this file to .env and fill in your actual values.

# Atlassian (Jira/Confluence) settings
ATLASSIAN_URL=https://your-domain.atlassian.net
ATLASSIAN_USER=your-email@example.com
ATLASSIAN_API_TOKEN=your_api_token_here

# Project and space settings
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY
CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY
CONFLUENCE_QA_REPORT_PARENT_ID=000000000
CONFLUENCE_TEST_PLAN_PARENT_ID=000000000
CONFLUENCE_MOR_PARENT_ID=000000000
